generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  PATIENT
  CLINIC_ADMIN
  CLINIC_STAFF
}

enum MedicationName {
  OZEMPIC
  WEGOVY
  MOUNJARO
  ZEPBOUND
  RYBELSUS
  SAXENDA
  OTHER
}

enum DoseFrequency {
  DAILY
  WEEKLY
}

enum SymptomSeverity {
  NONE
  MILD
  MODERATE
  SEVERE
}

enum RiskFlagLevel {
  INFO
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum RiskFlagStatus {
  OPEN
  REVIEWED
  RESOLVED
}

enum InviteType {
  PATIENT_TO_CLINIC
  CLINIC_TO_PATIENT
}

enum InviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

enum PatientAccessRole {
  VIEWER
  CLINICIAN
  ADMIN
}

model User {
  id        String   @id // Clerk userId
  email     String   @unique
  firstName String?
  lastName  String?
  role      UserRole @default(PATIENT)

  patientProfile PatientProfile?
  memberships    ClinicMembership[]
  sentInvites    PatientInvite[]     @relation("InviteSender")
  clinicNotes    ClinicPatientNote[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Clinic {
  id      String  @id @default(cuid())
  name    String
  slug    String  @unique
  phone   String?
  website String?
  address String?

  memberships ClinicMembership[]
  patients    PatientProfile[]
  invites     PatientInvite[]
  access      PatientAccess[]
  notes       ClinicPatientNote[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ClinicMembership {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  clinicId String
  clinic   Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  role UserRole @default(CLINIC_STAFF)

  createdAt DateTime @default(now())

  @@unique([userId, clinicId])
  @@index([clinicId])
}

model PatientProfile {
  id String @id @default(cuid())

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  clinicId String?
  clinic   Clinic? @relation(fields: [clinicId], references: [id], onDelete: SetNull)

  dateOfBirth      DateTime?
  sex              String?
  heightCm         Float?
  startWeightLb    Float?
  goalWeightLb     Float?
  proteinGoalGrams Int       @default(120)
  hydrationGoalOz  Int       @default(90)
  mainConcerns     String[]  @default([])
  riskEvaluatedAt  DateTime?

  medicationPlans  MedicationPlan[]
  doseLogs         DoseLog[]
  dailyCheckIns    DailyCheckIn[]
  weightLogs       WeightLog[]
  nutritionLogs    NutritionLog[]
  hydrationLogs    HydrationLog[]
  symptomLogs      SymptomLog[]
  riskFlags        RiskFlag[]
  doctorReports    DoctorReport[]
  invites          PatientInvite[]
  accessGrants     PatientAccess[]
  guidanceMessages GuidanceMessage[]
  clinicNotes      ClinicPatientNote[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clinicId])
}

model MedicationPlan {
  id String @id @default(cuid())

  patientId String
  patient   PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)

  medication MedicationName
  customName String?
  doseMg     Float
  frequency  DoseFrequency  @default(WEEKLY)

  startDate    DateTime
  nextDoseDate DateTime?
  active       Boolean   @default(true)

  notes String?

  doseLogs DoseLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([patientId])
  @@index([active])
}

model DoseLog {
  id String @id @default(cuid())

  patientId String
  patient   PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)

  medicationPlanId String?
  medicationPlan   MedicationPlan? @relation(fields: [medicationPlanId], references: [id], onDelete: SetNull)

  scheduledDate DateTime
  takenDate     DateTime?
  doseMg        Float
  taken         Boolean   @default(false)
  missed        Boolean   @default(false)

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([patientId])
  @@index([scheduledDate])
}

model DailyCheckIn {
  id String @id @default(cuid())

  patientId String
  patient   PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)

  checkInDate      DateTime
  appetiteLevel    Int? // 1-10
  energyLevel      Int? // 1-10
  moodLevel        Int? // 1-10
  movementMinutes  Int?
  strengthTraining Boolean  @default(false)
  bowelMovement    Boolean?

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([patientId, checkInDate])
  @@index([patientId])
}

model WeightLog {
  id String @id @default(cuid())

  patientId String
  patient   PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)

  loggedAt DateTime
  weightLb Float

  createdAt DateTime @default(now())

  @@index([patientId])
  @@index([loggedAt])
}

model NutritionLog {
  id String @id @default(cuid())

  patientId String
  patient   PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)

  loggedAt     DateTime
  proteinGrams Int?
  calories     Int?
  mealsLogged  Int?

  createdAt DateTime @default(now())

  @@index([patientId])
  @@index([loggedAt])
}

model HydrationLog {
  id String @id @default(cuid())

  patientId String
  patient   PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)

  loggedAt DateTime
  ounces   Int

  createdAt DateTime @default(now())

  @@index([patientId])
  @@index([loggedAt])
}

model SymptomLog {
  id String @id @default(cuid())

  patientId String
  patient   PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)

  loggedAt DateTime

  nausea        SymptomSeverity @default(NONE)
  vomiting      SymptomSeverity @default(NONE)
  constipation  SymptomSeverity @default(NONE)
  diarrhea      SymptomSeverity @default(NONE)
  reflux        SymptomSeverity @default(NONE)
  fatigue       SymptomSeverity @default(NONE)
  abdominalPain SymptomSeverity @default(NONE)

  notes String?

  createdAt DateTime @default(now())

  @@index([patientId])
  @@index([loggedAt])
}

model RiskFlag {
  id String @id @default(cuid())

  patientId String
  patient   PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)

  level  RiskFlagLevel
  status RiskFlagStatus @default(OPEN)

  title          String
  description    String
  recommendation String?

  source String? // example: "symptom-log", "hydration-log", "dose-log"

  createdAt  DateTime  @default(now())
  reviewedAt DateTime?
  resolvedAt DateTime?

  @@index([patientId])
  @@index([level])
  @@index([status])
}

model DoctorReport {
  id String @id @default(cuid())

  patientId String
  patient   PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)

  startDate DateTime
  endDate   DateTime

  summary      String
  flagsSummary String?
  reportData   Json

  createdAt DateTime @default(now())

  @@index([patientId])
  @@index([createdAt])
}

model PatientInvite {
  id String @id @default(cuid())

  type   InviteType
  status InviteStatus @default(PENDING)

  token        String @unique
  email        String
  invitedEmail String @default("")

  patientId String?
  patient   PatientProfile? @relation(fields: [patientId], references: [id], onDelete: Cascade)

  clinicId String?
  clinic   Clinic? @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  invitedByUserId String?
  invitedBy       User?   @relation("InviteSender", fields: [invitedByUserId], references: [id], onDelete: SetNull)

  expiresAt  DateTime
  acceptedAt DateTime?
  revokedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([token])
  @@index([patientId])
  @@index([clinicId])
  @@index([status])
}

model PatientAccess {
  id String @id @default(cuid())

  patientId String
  patient   PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)

  clinicId String
  clinic   Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  role              PatientAccessRole @default(CLINICIAN)
  grantedByInviteId String?

  revokedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([patientId, clinicId])
  @@index([patientId])
  @@index([clinicId])
  @@index([revokedAt])
}

model GuidanceMessage {
  id String @id @default(cuid())

  patientId String
  patient   PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)

  title    String
  message  String
  category String
  priority Int      @default(1)
  date     DateTime

  createdAt DateTime @default(now())

  @@index([patientId])
  @@index([date])
  @@index([priority])
}

model ClinicPatientNote {
  id String @id @default(cuid())

  patientId String
  patient   PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)

  clinicId String
  clinic   Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  authorUserId String
  author       User   @relation(fields: [authorUserId], references: [id], onDelete: Cascade)

  note String

  createdAt DateTime @default(now())

  @@index([patientId])
  @@index([clinicId])
  @@index([createdAt])
}
