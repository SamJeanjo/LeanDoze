generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  PATIENT
  CLINIC_ADMIN
  CLINIC_STAFF
}

enum MedicationName {
  OZEMPIC
  WEGOVY
  MOUNJARO
  ZEPBOUND
  RYBELSUS
  SAXENDA
  OTHER
}

enum DoseFrequency {
  DAILY
  WEEKLY
}

enum SymptomSeverity {
  NONE
  MILD
  MODERATE
  SEVERE
}

enum RiskFlagLevel {
  INFO
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum RiskFlagStatus {
  OPEN
  REVIEWED
  RESOLVED
}

model User {
  id        String   @id
  email     String   @unique
  firstName String?
  lastName  String?
  role      UserRole @default(PATIENT)

  patientProfile PatientProfile?
  memberships    ClinicMembership[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Clinic {
  id      String  @id @default(cuid())
  name    String
  slug    String  @unique
  phone   String?
  website String?
  address String?

  memberships ClinicMembership[]
  patients    PatientProfile[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ClinicMembership {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  clinicId String
  clinic   Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  role UserRole @default(CLINIC_STAFF)

  createdAt DateTime @default(now())

  @@unique([userId, clinicId])
  @@index([clinicId])
}

model PatientProfile {
  id String @id @default(cuid())

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  clinicId String?
  clinic   Clinic? @relation(fields: [clinicId], references: [id], onDelete: SetNull)

  dateOfBirth  DateTime?
  sex          String?
  heightCm     Float?
  startWeightLb Float?
  goalWeightLb  Float?

  medicationPlans MedicationPlan[]
  doseLogs        DoseLog[]
  dailyCheckIns   DailyCheckIn[]
  weightLogs      WeightLog[]
  nutritionLogs   NutritionLog[]
  hydrationLogs   HydrationLog[]
  symptomLogs     SymptomLog[]
  riskFlags       RiskFlag[]
  doctorReports   DoctorReport[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clinicId])
}

model MedicationPlan {
  id String @id @default(cuid())

  patientId String
  patient   PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)

  medication MedicationName
  customName String?
  doseMg     Float
  frequency  DoseFrequency @default(WEEKLY)

  startDate    DateTime
  nextDoseDate DateTime?
  active       Boolean   @default(true)

  notes String?

  doseLogs DoseLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([patientId])
  @@index([active])
}

model DoseLog {
  id String @id @default(cuid())

  patientId String
  patient   PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)

  medicationPlanId String?
  medicationPlan   MedicationPlan? @relation(fields: [medicationPlanId], references: [id], onDelete: SetNull)

  scheduledDate DateTime
  takenDate     DateTime?
  doseMg        Float
  taken         Boolean  @default(false)
  missed        Boolean  @default(false)

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([patientId])
  @@index([scheduledDate])
}

model DailyCheckIn {
  id String @id @default(cuid())

  patientId String
  patient   PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)

  checkInDate   DateTime
  appetiteLevel Int?
  energyLevel   Int?
  moodLevel     Int?

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([patientId, checkInDate])
  @@index([patientId])
}

model WeightLog {
  id String @id @default(cuid())

  patientId String
  patient   PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)

  loggedAt DateTime
  weightLb Float

  createdAt DateTime @default(now())

  @@index([patientId])
  @@index([loggedAt])
}

model NutritionLog {
  id String @id @default(cuid())

  patientId String
  patient   PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)

  loggedAt     DateTime
  proteinGrams Int?
  calories     Int?
  mealsLogged  Int?

  createdAt DateTime @default(now())

  @@index([patientId])
  @@index([loggedAt])
}

model HydrationLog {
  id String @id @default(cuid())

  patientId String
  patient   PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)

  loggedAt DateTime
  ounces   Int

  createdAt DateTime @default(now())

  @@index([patientId])
  @@index([loggedAt])
}

model SymptomLog {
  id String @id @default(cuid())

  patientId String
  patient   PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)

  loggedAt DateTime

  nausea        SymptomSeverity @default(NONE)
  vomiting      SymptomSeverity @default(NONE)
  constipation  SymptomSeverity @default(NONE)
  diarrhea      SymptomSeverity @default(NONE)
  reflux        SymptomSeverity @default(NONE)
  fatigue       SymptomSeverity @default(NONE)
  abdominalPain SymptomSeverity @default(NONE)

  notes String?

  createdAt DateTime @default(now())

  @@index([patientId])
  @@index([loggedAt])
}

model RiskFlag {
  id String @id @default(cuid())

  patientId String
  patient   PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)

  level  RiskFlagLevel
  status RiskFlagStatus @default(OPEN)

  title          String
  description    String
  recommendation String?

  source String?

  createdAt  DateTime  @default(now())
  reviewedAt DateTime?
  resolvedAt DateTime?

  @@index([patientId])
  @@index([level])
  @@index([status])
}

model DoctorReport {
  id String @id @default(cuid())

  patientId String
  patient   PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)

  startDate DateTime
  endDate   DateTime

  summary      String
  flagsSummary String?
  reportData   Json

  createdAt DateTime @default(now())

  @@index([patientId])
  @@index([createdAt])
}
